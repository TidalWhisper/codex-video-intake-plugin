{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stage 04 Keyframe Prompts",
  "type": "object",
  "required": [
    "schema_version",
    "stage",
    "status",
    "project_id",
    "source_brief",
    "source_script",
    "source_storyboard",
    "source_character_bible",
    "shot_prompts",
    "transition_prompts",
    "global_negative_prompt",
    "self_check",
    "allowed_next_stage"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "stage": {
      "const": "STAGE_04_KEYFRAME_PROMPTS"
    },
    "status": {
      "enum": [
        "draft",
        "confirmed"
      ]
    },
    "project_id": {
      "type": "string"
    },
    "shot_prompts": {
      "type": "array"
    },
    "transition_prompts": {
      "type": "array"
    }
  }
}