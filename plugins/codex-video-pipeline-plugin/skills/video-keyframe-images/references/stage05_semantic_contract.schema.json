{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stage 05 Semantic Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mode",
    "source",
    "defaults",
    "provider_strategy",
    "bootstrap",
    "jobs",
    "self_check"
  ],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["codex_contract"]
    },
    "source": {
      "type": "string"
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage05_mode",
        "comfyui_control_mode",
        "prompt_composition_mode"
      ],
      "properties": {
        "stage05_mode": {
          "type": "string",
          "enum": ["reference_guided_storyboard"]
        },
        "stage05_route_key": {
          "type": "string"
        },
        "style_family": {
          "type": "string"
        },
        "comfyui_workflow_mapping_key": {
          "type": "string"
        },
        "comfyui_workflow_name": {
          "type": "string"
        },
        "comfyui_model_id": {
          "type": "string"
        },
        "preferred_comfyui_workflow_candidate": {
          "type": "string"
        },
        "preferred_comfyui_model_candidate": {
          "type": "string"
        },
        "preferred_comfyui_workflow_source_ref": {
          "type": "string"
        },
        "preferred_comfyui_workflow_format": {
          "type": "string"
        },
        "preferred_comfyui_workflow_custom_node_dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "preferred_comfyui_workflow_import_blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "comfyui_style_preset_key": {
          "type": ["string", "null"]
        },
        "comfyui_style_preset_label": {
          "type": ["string", "null"]
        },
        "comfyui_style_positive_anchor": {
          "type": ["string", "null"]
        },
        "comfyui_style_negative_anchor": {
          "type": ["string", "null"]
        },
        "comfyui_style_selector": {
          "type": ["string", "null"]
        },
        "comfyui_control_mode": {
          "type": "string",
          "enum": ["reference_guided"]
        },
        "prompt_composition_mode": {
          "type": "string",
          "enum": ["codex_contract"]
        },
        "provider_priority": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "provider_strategy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "fallback", "execution_mode", "notes"],
      "properties": {
        "primary": {
          "type": "string"
        },
        "fallback": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "execution_mode": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "bootstrap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "semantic_source",
        "required",
        "target_reference_image_path",
        "provider_prompt",
        "negative_prompt",
        "lighting_prompt",
        "camera_and_style_prompt"
      ],
      "properties": {
        "semantic_source": {
          "type": "string",
          "enum": ["codex_contract"]
        },
        "required": {
          "type": "boolean"
        },
        "target_reference_image_path": {
          "type": "string"
        },
        "workflow_mapping_key": {
          "type": "string"
        },
        "workflow_name": {
          "type": "string"
        },
        "comfyui_model_id": {
          "type": "string"
        },
        "preferred_workflow_candidate": {
          "type": "string"
        },
        "preferred_workflow_source_ref": {
          "type": "string"
        },
        "preferred_workflow_format": {
          "type": "string"
        },
        "style_preset_key": {
          "type": ["string", "null"]
        },
        "style_preset_label": {
          "type": ["string", "null"]
        },
        "style_positive_anchor": {
          "type": ["string", "null"]
        },
        "style_negative_anchor": {
          "type": ["string", "null"]
        },
        "style_selector": {
          "type": ["string", "null"]
        },
        "provider_prompt": {
          "type": "string"
        },
        "negative_prompt": {
          "type": "string"
        },
        "lighting_prompt": {
          "type": "string"
        },
        "camera_and_style_prompt": {
          "type": "string"
        }
      }
    },
    "jobs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "shot_id",
          "frame_role",
          "semantic_source",
          "provider_prompt",
          "negative_prompt",
          "reference_images",
          "stage06_route_hint",
          "stage06_requires_mid_guide",
          "review",
          "repair"
        ],
        "properties": {
          "shot_id": {
            "type": "string"
          },
          "frame_role": {
            "type": "string",
            "enum": ["start", "mid", "end"]
          },
          "semantic_source": {
            "type": "string",
            "enum": ["codex_contract"]
          },
          "provider_prompt": {
            "type": "string"
          },
          "negative_prompt": {
            "type": "string"
          },
          "reference_images": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "secondary_reference_images": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "reference_bundle_mode": {
            "type": ["string", "null"]
          },
          "stage06_route_hint": {
            "type": "string"
          },
          "stage06_requires_mid_guide": {
            "type": "boolean"
          },
          "comfyui_workflow_mapping_key": {
            "type": ["string", "null"]
          },
          "comfyui_workflow_name": {
            "type": ["string", "null"]
          },
          "comfyui_model_id": {
            "type": ["string", "null"]
          },
          "preferred_comfyui_workflow_candidate": {
            "type": ["string", "null"]
          },
          "preferred_comfyui_model_candidate": {
            "type": ["string", "null"]
          },
          "preferred_comfyui_workflow_source_ref": {
            "type": ["string", "null"]
          },
          "preferred_comfyui_workflow_format": {
            "type": ["string", "null"]
          },
          "preferred_comfyui_workflow_custom_node_dependencies": {
            "type": ["array", "null"],
            "items": {
              "type": "string"
            }
          },
          "preferred_comfyui_workflow_import_blockers": {
            "type": ["array", "null"],
            "items": {
              "type": "string"
            }
          },
          "comfyui_style_preset_key": {
            "type": ["string", "null"]
          },
          "comfyui_style_preset_label": {
            "type": ["string", "null"]
          },
          "comfyui_style_positive_anchor": {
            "type": ["string", "null"]
          },
          "comfyui_style_negative_anchor": {
            "type": ["string", "null"]
          },
          "comfyui_style_selector": {
            "type": ["string", "null"]
          },
          "comfyui_control_mode": {
            "type": ["string", "null"]
          },
          "review": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "semantic_source",
              "risk_tags",
              "requires_manual_review",
              "review_focus",
              "creator_repair_suggestions",
              "review_priority_score",
              "auto_repair_recommended"
            ],
            "properties": {
              "semantic_source": {
                "type": "string",
                "enum": ["codex_contract"]
              },
              "risk_tags": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "control_mode": {
                "type": "string"
              },
              "requires_manual_review": {
                "type": "boolean"
              },
              "manual_review_status": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              },
              "creator_risk_summary": {
                "type": "string"
              },
              "creator_repair_suggestions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "review_priority_score": {
                "type": "integer"
              },
              "review_priority_label": {
                "type": "string"
              },
              "review_priority_bucket": {
                "type": "string"
              },
              "review_checklist": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "review_focus": {
                "type": "string"
              },
              "auto_repair_recommended": {
                "type": "boolean"
              }
            }
          },
          "repair": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "enabled",
              "mode",
              "target_failure_modes",
              "creator_repair_suggestions",
              "repair_prompt_sections",
              "repair_negative_hints"
            ],
            "properties": {
              "enabled": {
                "type": "boolean"
              },
              "mode": {
                "type": "string"
              },
              "target_failure_modes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "reason": {
                "type": "string"
              },
              "creator_summary": {
                "type": "string"
              },
              "creator_repair_suggestions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "repair_prompt_sections": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "repair_negative_hints": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "pass_count": {
                "type": "integer"
              }
            }
          },
          "review_card": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "headline": {
                "type": "string"
              },
              "priority_label": {
                "type": "string"
              },
              "priority_score": {
                "type": "integer"
              },
              "focus": {
                "type": "string"
              },
              "checklist": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "suggestions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "next_step": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "self_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "matches_stage04_prompts",
        "preserves_reference_guided_mainline",
        "python_can_execute_mechanically"
      ],
      "properties": {
        "matches_stage04_prompts": {
          "type": "boolean"
        },
        "preserves_reference_guided_mainline": {
          "type": "boolean"
        },
        "python_can_execute_mechanically": {
          "type": "boolean"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
