{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stage 02 LLM Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "target_duration_sec",
    "shots",
    "self_check"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["draft", "confirmed"]
    },
    "target_duration_sec": {
      "type": "integer",
      "minimum": 1
    },
    "shots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "shot_id",
          "start",
          "end",
          "duration_sec",
          "scene",
          "camera",
          "composition",
          "action",
          "emotion",
          "dialogue",
          "voiceover",
          "sound_music",
          "transition_to_next",
          "production_note"
        ],
        "properties": {
          "shot_id": {"type": "string"},
          "start": {"type": "string"},
          "end": {"type": "string"},
          "duration_sec": {"type": "number", "exclusiveMinimum": 0},
          "scene": {"type": "string"},
          "location": {"type": "string"},
          "weather": {"type": "string"},
          "key_prop": {"type": "string"},
          "camera": {"type": "string"},
          "composition": {"type": "string"},
          "composition_focus": {"type": "string"},
          "action": {"type": "string"},
          "emotion": {"type": "string"},
          "dialogue": {"type": "string"},
          "voiceover": {"type": "string"},
          "sound_music": {"type": "string"},
          "transition_to_next": {"type": "string"},
          "production_note": {"type": "string"}
        }
      }
    },
    "self_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "matches_locked_brief",
        "matches_script",
        "duration_fits",
        "ready_for_character_stage"
      ],
      "properties": {
        "matches_locked_brief": {"type": "boolean"},
        "matches_script": {"type": "boolean"},
        "duration_fits": {"type": "boolean"},
        "ready_for_character_stage": {"type": "boolean"},
        "notes": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  }
}
